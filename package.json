{
	"name": "pro-api-sdk",
	"version": "1.3.2",
	"description": "嘉立创EDA & EasyEDA 专业版扩展 API 开发工具 (Bun 版本)",
	"author": "JLCEDA <support@lceda.cn>",
	"license": "Apache-2.0",
	"homepage": "https://pro.lceda.cn/",
	"engines": {
		"bun": ">=1.0.0"
	},
	"scripts": {
		"compile": "rimraf ./dist/ && bun ./config/esbuild.prod.ts",
		"lint": "eslint",
		"fix": "eslint --fix",
		"build": "bun run compile && bun ./build/packaged.ts",
		"typecheck": "bun run --bun tsc --noEmit"
	},
	"devDependencies": {
		"@antfu/eslint-config": "^5.4.1",
		"@jlceda/pro-api-types": "^0.2.13",
		"@types/fs-extra": "^11.0.4",
		"@types/react": "^19.2.14",
		"bun-types": "^1.3.10",
		"esbuild": "^0.24.2",
		"eslint": "^9.37.0",
		"fs-extra": "^11.3.0",
		"ignore": "^7.0.3",
		"jszip": "^3.10.1",
		"rimraf": "^6.0.1",
		"typescript": "^5.7.3"
	},
	"bun-create": {
		"postinstall": "echo '✅ pro-api-sdk 项目已创建！运行 bun run build 进行构建。'"
	}
}
